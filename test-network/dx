name: compose
services:
  orderer.example.com:
    command:
      - orderer
    container_name: orderer.example.com
    environment:
      FABRIC_LOGGING_SPEC: INFO
      ORDERER_ADMIN_LISTENADDRESS: 0.0.0.0:7053
      ORDERER_ADMIN_TLS_CERTIFICATE: /var/hyperledger/orderer/tls/server.crt
      ORDERER_ADMIN_TLS_CLIENTROOTCAS: '[/var/hyperledger/orderer/tls/ca.crt]'
      ORDERER_ADMIN_TLS_ENABLED: "true"
      ORDERER_ADMIN_TLS_PRIVATEKEY: /var/hyperledger/orderer/tls/server.key
      ORDERER_ADMIN_TLS_ROOTCAS: '[/var/hyperledger/orderer/tls/ca.crt]'
      ORDERER_CHANNELPARTICIPATION_ENABLED: "true"
      ORDERER_GENERAL_BOOTSTRAPMETHOD: none
      ORDERER_GENERAL_CLUSTER_CLIENTCERTIFICATE: /var/hyperledger/orderer/tls/server.crt
      ORDERER_GENERAL_CLUSTER_CLIENTPRIVATEKEY: /var/hyperledger/orderer/tls/server.key
      ORDERER_GENERAL_CLUSTER_ROOTCAS: '[/var/hyperledger/orderer/tls/ca.crt]'
      ORDERER_GENERAL_LISTENADDRESS: 0.0.0.0
      ORDERER_GENERAL_LISTENPORT: "7050"
      ORDERER_GENERAL_LOCALMSPDIR: /var/hyperledger/orderer/msp
      ORDERER_GENERAL_LOCALMSPID: OrdererMSP
      ORDERER_GENERAL_TLS_CERTIFICATE: /var/hyperledger/orderer/tls/server.crt
      ORDERER_GENERAL_TLS_ENABLED: "true"
      ORDERER_GENERAL_TLS_PRIVATEKEY: /var/hyperledger/orderer/tls/server.key
      ORDERER_GENERAL_TLS_ROOTCAS: '[/var/hyperledger/orderer/tls/ca.crt]'
      ORDERER_METRICS_PROVIDER: prometheus
      ORDERER_OPERATIONS_LISTENADDRESS: orderer.example.com:9443
    image: hyperledger/fabric-orderer:latest
    labels:
      service: hyperledger-fabric
    networks:
      test: null
    ports:
      - mode: ingress
        target: 7050
        published: "7050"
        protocol: tcp
      - mode: ingress
        target: 7053
        published: "7053"
        protocol: tcp
      - mode: ingress
        target: 9443
        published: "9443"
        protocol: tcp
    volumes:
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/organizations/ordererOrganizations/example.com/orderers/orderer.example.com/msp
        target: /var/hyperledger/orderer/msp
        bind: {}
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/organizations/ordererOrganizations/example.com/orderers/orderer.example.com/tls
        target: /var/hyperledger/orderer/tls
        bind: {}
      - type: volume
        source: orderer.example.com
        target: /var/hyperledger/production/orderer
        volume: {}
    working_dir: /root
  peer0.org1.example.com:
    command:
      - peer
      - node
      - start
    container_name: peer0.org1.example.com
    environment:
      CHAINCODE_AS_A_SERVICE_BUILDER_CONFIG: '{"peername":"peer0org1"}'
      CORE_CHAINCODE_EXECUTETIMEOUT: 300s
      CORE_METRICS_PROVIDER: prometheus
      CORE_OPERATIONS_LISTENADDRESS: peer0.org1.example.com:9444
      CORE_PEER_ADDRESS: peer0.org1.example.com:7051
      CORE_PEER_CHAINCODEADDRESS: peer0.org1.example.com:7052
      CORE_PEER_CHAINCODELISTENADDRESS: 0.0.0.0:7052
      CORE_PEER_GOSSIP_BOOTSTRAP: peer0.org1.example.com:7051
      CORE_PEER_GOSSIP_EXTERNALENDPOINT: peer0.org1.example.com:7051
      CORE_PEER_ID: peer0.org1.example.com
      CORE_PEER_LISTENADDRESS: 0.0.0.0:7051
      CORE_PEER_LOCALMSPID: Org1MSP
      CORE_PEER_MSPCONFIGPATH: /etc/hyperledger/fabric/msp
      CORE_PEER_PROFILE_ENABLED: "false"
      CORE_PEER_TLS_CERT_FILE: /etc/hyperledger/fabric/tls/server.crt
      CORE_PEER_TLS_ENABLED: "true"
      CORE_PEER_TLS_KEY_FILE: /etc/hyperledger/fabric/tls/server.key
      CORE_PEER_TLS_ROOTCERT_FILE: /etc/hyperledger/fabric/tls/ca.crt
      FABRIC_CFG_PATH: /etc/hyperledger/peercfg
      FABRIC_LOGGING_SPEC: INFO
    image: hyperledger/fabric-peer:latest
    labels:
      service: hyperledger-fabric
    networks:
      test: null
    ports:
      - mode: ingress
        target: 7051
        published: "7051"
        protocol: tcp
      - mode: ingress
        target: 9444
        published: "9444"
        protocol: tcp
    volumes:
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com
        target: /etc/hyperledger/fabric
        bind: {}
      - type: volume
        source: peer0.org1.example.com
        target: /var/hyperledger/production
        volume: {}
    working_dir: /root
  peer0.org2.example.com:
    command:
      - peer
      - node
      - start
    container_name: peer0.org2.example.com
    environment:
      CHAINCODE_AS_A_SERVICE_BUILDER_CONFIG: '{"peername":"peer0org2"}'
      CORE_CHAINCODE_EXECUTETIMEOUT: 300s
      CORE_METRICS_PROVIDER: prometheus
      CORE_OPERATIONS_LISTENADDRESS: peer0.org2.example.com:9445
      CORE_PEER_ADDRESS: peer0.org2.example.com:9051
      CORE_PEER_CHAINCODEADDRESS: peer0.org2.example.com:9052
      CORE_PEER_CHAINCODELISTENADDRESS: 0.0.0.0:9052
      CORE_PEER_GOSSIP_BOOTSTRAP: peer0.org2.example.com:9051
      CORE_PEER_GOSSIP_EXTERNALENDPOINT: peer0.org2.example.com:9051
      CORE_PEER_ID: peer0.org2.example.com
      CORE_PEER_LISTENADDRESS: 0.0.0.0:9051
      CORE_PEER_LOCALMSPID: Org2MSP
      CORE_PEER_MSPCONFIGPATH: /etc/hyperledger/fabric/msp
      CORE_PEER_PROFILE_ENABLED: "false"
      CORE_PEER_TLS_CERT_FILE: /etc/hyperledger/fabric/tls/server.crt
      CORE_PEER_TLS_ENABLED: "true"
      CORE_PEER_TLS_KEY_FILE: /etc/hyperledger/fabric/tls/server.key
      CORE_PEER_TLS_ROOTCERT_FILE: /etc/hyperledger/fabric/tls/ca.crt
      FABRIC_CFG_PATH: /etc/hyperledger/peercfg
      FABRIC_LOGGING_SPEC: INFO
    image: hyperledger/fabric-peer:latest
    labels:
      service: hyperledger-fabric
    networks:
      test: null
    ports:
      - mode: ingress
        target: 9051
        published: "9051"
        protocol: tcp
      - mode: ingress
        target: 9446
        published: "9446"
        protocol: tcp
    volumes:
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/organizations/peerOrganizations/org2.example.com/peers/peer0.org2.example.com
        target: /etc/hyperledger/fabric
        bind: {}
      - type: volume
        source: peer0.org2.example.com
        target: /var/hyperledger/production
        volume: {}
    working_dir: /root
  peer1.org1.example.com:
    command:
      - peer
      - node
      - start
    container_name: peer1.org1.example.com
    environment:
      CHAINCODE_AS_A_SERVICE_BUILDER_CONFIG: '{"peername":"peer1org1"}'
      CORE_CHAINCODE_EXECUTETIMEOUT: 300s
      CORE_METRICS_PROVIDER: prometheus
      CORE_OPERATIONS_LISTENADDRESS: peer1.org1.example.com:9445
      CORE_PEER_ADDRESS: peer1.org1.example.com:8051
      CORE_PEER_CHAINCODEADDRESS: peer1.org1.example.com:8052
      CORE_PEER_CHAINCODELISTENADDRESS: 0.0.0.0:8052
      CORE_PEER_GOSSIP_BOOTSTRAP: peer0.org1.example.com:7051
      CORE_PEER_GOSSIP_EXTERNALENDPOINT: peer1.org1.example.com:8051
      CORE_PEER_ID: peer1.org1.example.com
      CORE_PEER_LISTENADDRESS: 0.0.0.0:8051
      CORE_PEER_LOCALMSPID: Org1MSP
      CORE_PEER_MSPCONFIGPATH: /etc/hyperledger/fabric/msp
      CORE_PEER_PROFILE_ENABLED: "false"
      CORE_PEER_TLS_CERT_FILE: /etc/hyperledger/fabric/tls/server.crt
      CORE_PEER_TLS_ENABLED: "true"
      CORE_PEER_TLS_KEY_FILE: /etc/hyperledger/fabric/tls/server.key
      CORE_PEER_TLS_ROOTCERT_FILE: /etc/hyperledger/fabric/tls/ca.crt
      FABRIC_CFG_PATH: /etc/hyperledger/peercfg
      FABRIC_LOGGING_SPEC: INFO
    image: hyperledger/fabric-peer:latest
    labels:
      service: hyperledger-fabric
    networks:
      test: null
    ports:
      - mode: ingress
        target: 7051
        published: "8051"
        protocol: tcp
      - mode: ingress
        target: 9445
        published: "9445"
        protocol: tcp
    volumes:
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer1.org1.example.com
        target: /etc/hyperledger/fabric
        bind: {}
      - type: bind
        source: /home/prnv/dockertest/fabric-samples/test-network/config/core.yaml
        target: /etc/hyperledger/peercfg/core.yaml
        bind: {}
      - type: volume
        source: peer1.org1.example.com
        target: /var/hyperledger/production
        volume: {}
    working_dir: /root
networks:
  test:
    name: fabric_test
volumes:
  orderer.example.com:
    name: compose_orderer.example.com
  peer0.org1.example.com:
    name: compose_peer0.org1.example.com
  peer0.org2.example.com:
    name: compose_peer0.org2.example.com
  peer1.org1.example.com:
    name: compose_peer1.org1.example.com
